{
  "name": "iframe-link-card",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "WRANGLER_WRITE_LOGS=false $npm_execpath run build && vitest run",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "oxfmt",
    "lint": "oxlint"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.2",
    "miniflare": "^4.20260623.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "vite": "^8.1.0",
    "vite-ssr-components": "^0.6.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
